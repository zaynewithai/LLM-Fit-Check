# =============================================================================
# LLM Fit Check — environment configuration
# Copy this file to `.env` and fill in real values before running.
# =============================================================================

# --- Database ---------------------------------------------------------------
# Primary: PostgreSQL. Fallback: SQLite (zero-config local dev).
# To switch, change the Prisma `provider` in prisma/schema.prisma AND set this URL.
#
# PostgreSQL example: postgresql://user:pass@host:5432/llmfitcheck?schema=public
# SQLite example (local dev): file:./dev.db
DATABASE_URL="file:./dev.db"

# --- Hugging Face (OPTIONAL) ------------------------------------------------
# Only needed to sync gated repos (some Meta / Google releases).
# Leave empty for public repos — they sync without a token.
# Never sent to the browser.
HF_TOKEN=""

# --- Sync protection --------------------------------------------------------
# Long random string. POST /api/sync requires the header `x-sync-secret: <this>`.
SYNC_SECRET=""

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="LLM Fit Check"

# --- Google AdSense (OPTIONAL — for ad monetization) ------------------------
# Leave empty to show placeholder ads (dev). Set to your AdSense publisher ID
# to serve real ads. Format: ca-pub-XXXXXXXXXXXXXXXX
# Get it at: https://www.google.com/adsense → My account → Account information
NEXT_PUBLIC_ADSENSE_CLIENT=""
