// Prisma schema for LLMFitCheck.
// Switching between SQLite (local) and PostgreSQL (prod) is a one-line change
// to the `provider` below — the field types are provider-agnostic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local dev: "sqlite" + DATABASE_URL="file:./dev.db"
  // Vercel/prod: "postgresql" + DATABASE_URL from Vercel Postgres
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Model {
  id            Int       @id @default(autoincrement())
  slug          String    @unique
  name          String
  repo          String    @unique
  family        String
  totalParams   Float
  activeParams  Float?
  isMoE         Boolean   @default(false)
  openWeights   Boolean   @default(true)
  gated         Boolean   @default(false)
  downloads     Int       @default(0)
  likes         Int       @default(0)
  // Anatomical fields from config.json (for precise KV cache calculation).
  // Null when not yet fetched or unavailable — falls back to empirical formula.
  numLayers     Int?
  numKvHeads    Int?
  numQHeads     Int?
  headDim       Int?
  hiddenSize    Int?
  createdAt     DateTime?
  lastSyncedAt  DateTime?

  @@index([family])
  @@index([totalParams])
  @@index([isMoE])
  @@index([downloads])
}

model SyncLog {
  id          Int       @id @default(autoincrement())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  success     Int       @default(0)
  failed      Int       @default(0)
  skipped     Int       @default(0)
  discovered  Int       @default(0)
  message     String?

  @@map("sync_log")
}
